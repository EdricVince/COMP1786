<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── Brand ─────────────────────────────────────────────────────────── -->
    <Color x:Key="Primary">#7B61FF</Color>
    <Color x:Key="PrimaryDark">#5B3FDF</Color>
    <Color x:Key="PrimaryLight">#EDE9FF</Color>
    <Color x:Key="Accent">#FF7043</Color>
    <Color x:Key="AccentLight">#FFF0EC</Color>

    <!-- ── Surfaces ──────────────────────────────────────────────────────── -->
    <Color x:Key="CardDark">#1E1E2D</Color>
    <Color x:Key="CardDark2">#2D2B55</Color>
    <Color x:Key="Background">#F5F5FA</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="Divider">#EFEFEF</Color>

    <!-- ── Text ──────────────────────────────────────────────────────────── -->
    <Color x:Key="TextPrimary">#1E1E2D</Color>
    <Color x:Key="TextSecondary">#7C7C8A</Color>
    <Color x:Key="TextHint">#BCBCC8</Color>
    <Color x:Key="OnPrimary">#FFFFFF</Color>

    <!-- ── Status: Active ────────────────────────────────────────────────── -->
    <Color x:Key="ActiveBg">#E8F9EE</Color>
    <Color x:Key="ActiveText">#1A9E4A</Color>

    <!-- ── Status: Completed ─────────────────────────────────────────────── -->
    <Color x:Key="CompletedBg">#E8F0FF</Color>
    <Color x:Key="CompletedText">#2563EB</Color>

    <!-- ── Status: On Hold ───────────────────────────────────────────────── -->
    <Color x:Key="OnHoldBg">#FFF4E5</Color>
    <Color x:Key="OnHoldText">#D97706</Color>

    <!-- ── Payment status ────────────────────────────────────────────────── -->
    <Color x:Key="PaidBg">#E8F9EE</Color>
    <Color x:Key="PaidText">#1A9E4A</Color>
    <Color x:Key="PendingBg">#FFF4E5</Color>
    <Color x:Key="PendingText">#D97706</Color>
    <Color x:Key="ReimbursedBg">#E8F0FF</Color>
    <Color x:Key="ReimbursedText">#2563EB</Color>

    <!-- ── Misc ──────────────────────────────────────────────────────────── -->
    <Color x:Key="GreenAccent">#5EF5A0</Color>
    <Color x:Key="DarkCardText">#AAAACC</Color>
    <Color x:Key="Error">#EF4444</Color>
</ResourceDictionary>
