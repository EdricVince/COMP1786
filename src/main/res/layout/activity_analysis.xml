<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            style="@style/Widget.ExpenseTracker.Toolbar"
            app:title="Analysis"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp">

            <!-- ── Summary dark card ──────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.ExpenseTracker.DarkCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_dark"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Financial Overview"
                        android:textColor="#AAAACC"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView android:id="@+id/tvAnalysisTotalBudget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textColor="@color/white"
                        android:textSize="34sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="20dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#33FFFFFF"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Spent"
                                android:textColor="#AAAACC"
                                android:textSize="12sp"/>
                            <TextView android:id="@+id/tvAnalysisTotalSpent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0.00"
                                android:textColor="@color/accent"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Remaining"
                                android:textColor="#AAAACC"
                                android:textSize="12sp"/>
                            <TextView android:id="@+id/tvAnalysisRemaining"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0.00"
                                android:textColor="#5EF5A0"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Utilization"
                                android:textColor="#AAAACC"
                                android:textSize="12sp"/>
                            <TextView android:id="@+id/tvAnalysisUtilization"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Project counts card ───────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.ExpenseTracker.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Budgets by Status"
                        style="@style/Widget.ExpenseTracker.SectionTitle"
                        android:layout_marginBottom="16dp"/>

                    <!-- Active -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Active"
                            android:textColor="@color/status_active_text"
                            android:textSize="13sp"/>
                        <FrameLayout android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_progress_track"
                            android:layout_marginHorizontal="10dp">
                            <View android:id="@+id/barActive"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="@color/status_active_text"/>
                        </FrameLayout>
                        <TextView android:id="@+id/tvActiveCount"
                            android:layout_width="30dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Completed -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Completed"
                            android:textColor="@color/status_completed_text"
                            android:textSize="13sp"/>
                        <FrameLayout android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_progress_track"
                            android:layout_marginHorizontal="10dp">
                            <View android:id="@+id/barCompleted"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="@color/status_completed_text"/>
                        </FrameLayout>
                        <TextView android:id="@+id/tvCompletedCount"
                            android:layout_width="30dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- On Hold -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="On Hold"
                            android:textColor="@color/status_on_hold_text"
                            android:textSize="13sp"/>
                        <FrameLayout android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_progress_track"
                            android:layout_marginHorizontal="10dp">
                            <View android:id="@+id/barOnHold"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="@color/status_on_hold_text"/>
                        </FrameLayout>
                        <TextView android:id="@+id/tvOnHoldCount"
                            android:layout_width="30dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="end"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Expenses by type card ──────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.ExpenseTracker.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <TextView android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Expenses by Type"
                            style="@style/Widget.ExpenseTracker.SectionTitle"/>
                        <TextView android:id="@+id/tvTotalExpenseCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/layoutExpenseTypes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Payment status card ───────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.ExpenseTracker.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment Status"
                        style="@style/Widget.ExpenseTracker.SectionTitle"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@color/paid_bg"
                            android:padding="14dp"
                            android:layout_marginEnd="6dp">
                            <TextView android:id="@+id/tvPaidCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/paid_text"
                                android:textSize="24sp"
                                android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Paid"
                                android:textColor="@color/paid_text"
                                android:textSize="12sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@color/pending_bg"
                            android:padding="14dp"
                            android:layout_marginHorizontal="3dp">
                            <TextView android:id="@+id/tvPendingCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/pending_text"
                                android:textSize="24sp"
                                android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending"
                                android:textColor="@color/pending_text"
                                android:textSize="12sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@color/reimbursed_bg"
                            android:padding="14dp"
                            android:layout_marginStart="6dp">
                            <TextView android:id="@+id/tvReimbursedCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/reimbursed_text"
                                android:textSize="24sp"
                                android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reimbursed"
                                android:textColor="@color/reimbursed_text"
                                android:textSize="12sp"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Top projects by spending ──────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.ExpenseTracker.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Top Budgets by Spending"
                        style="@style/Widget.ExpenseTracker.SectionTitle"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout android:id="@+id/layoutTopProjects"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        app:elevation="16dp"
        app:menu="@menu/menu_bottom_nav"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
