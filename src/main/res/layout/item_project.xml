<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.ExpenseTracker.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:rippleColor="@color/ripple">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Selection Checkbox (Visible only in delete mode) -->
        <CheckBox
            android:id="@+id/cbProjectDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Row 1: code + status chip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView android:id="@+id/tvProjectCode"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"/>

                <!-- Uploaded badge -->
                <TextView android:id="@+id/tvProjectUploaded"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="☁"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"/>

                <!-- Status chip -->
                <TextView android:id="@+id/tvProjectStatus"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_chip"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"/>
            </LinearLayout>

            <!-- Row 2: Project name -->
            <TextView android:id="@+id/tvProjectName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="4dp"/>

            <!-- Row 3: Manager -->
            <TextView android:id="@+id/tvProjectManager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="14dp"/>

            <!-- Budget progress bar -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <TextView android:id="@+id/tvProjectBudget"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
                <TextView android:id="@+id/tvProjectPercent"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <!-- Progress bar track -->
            <FrameLayout android:layout_width="match_parent"
                android:layout_height="6dp"
                android:background="@drawable/bg_progress_track"
                android:layout_marginBottom="12dp">
                <View android:id="@+id/viewProgress"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_progress_fill"/>
            </FrameLayout>

            <!-- Row 4: dates -->
            <TextView android:id="@+id/tvProjectDates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_hint"
                android:textSize="12sp"/>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>