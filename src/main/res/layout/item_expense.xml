<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.ExpenseTracker.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:rippleColor="@color/ripple">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Left: category icon circle -->
        <TextView android:id="@+id/tvExpenseIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_expense_icon"
            android:gravity="center"
            android:text="💳"
            android:textSize="20sp"
            android:layout_marginEnd="14dp"/>

        <!-- Center: type + claimant + method -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView android:id="@+id/tvExpenseType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView android:id="@+id/tvExpenseClaimant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <LinearLayout android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">
                <TextView android:id="@+id/tvExpensePaymentMethod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp"/>
                <View android:layout_width="4dp" android:layout_height="4dp"
                    android:background="@drawable/bg_dot"
                    android:layout_marginHorizontal="6dp"/>
                <TextView android:id="@+id/tvExpenseDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Right: amount + status chip -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView android:id="@+id/tvExpenseAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="6dp"/>

            <TextView android:id="@+id/tvExpenseStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_chip"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"/>

            <!-- Hidden code for reference -->
            <TextView android:id="@+id/tvExpenseCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
