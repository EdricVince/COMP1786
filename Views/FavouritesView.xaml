<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectExpenseTracker.Views.FavouritesView"
             BackgroundColor="#F0F0FA"
             Title="Favourites">

    <Grid RowDefinitions="Auto,*">

        <!-- Header card -->
        <Frame Grid.Row="0" Margin="16,16,16,8"
               BackgroundColor="#1E1E2D" CornerRadius="16"
               HasShadow="False" Padding="16,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackLayout Grid.Column="0" Spacing="2">
                    <Label Text="⭐  Starred Projects" TextColor="#AAAACC"
                           FontSize="12" FontAttributes="Bold"/>
                    <Label x:Name="lblFavCount" Text="0 projects"
                           TextColor="White" FontSize="18" FontAttributes="Bold"/>
                </StackLayout>
                <Label Grid.Column="1" Text="♥" TextColor="#FF7043"
                       FontSize="32" VerticalOptions="Center"/>
            </Grid>
        </Frame>

        <!-- Favourites list -->
        <CollectionView Grid.Row="1" x:Name="cvFavourites" Margin="16,0,16,16">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,10" BackgroundColor="White"
                           CornerRadius="16" HasShadow="False" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding Name}" TextColor="#1E1E2D"
                                       FontSize="16" FontAttributes="Bold"/>
                                <Label Text="{Binding Manager, StringFormat='👤  {0}'}"
                                       TextColor="#7C7C8A" FontSize="13"/>
                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                                    <Label Grid.Column="0"
                                           Text="{Binding Budget, StringFormat='${0:N0}'}"
                                           TextColor="#7B61FF" FontSize="14"
                                           FontAttributes="Bold"/>
                                    <Frame Grid.Column="1" Padding="8,3"
                                           CornerRadius="8" HasShadow="False"
                                           BackgroundColor="{Binding StatusBg}">
                                        <Label Text="{Binding Status}"
                                               TextColor="{Binding StatusColor}"
                                               FontSize="11" FontAttributes="Bold"/>
                                    </Frame>
                                </Grid>
                            </StackLayout>
                            <Button Grid.Column="1" Text="♥"
                                    TextColor="#FF7043"
                                    BackgroundColor="Transparent"
                                    FontSize="24" VerticalOptions="Center"
                                    Clicked="OnRemoveFavourite"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <StackLayout HorizontalOptions="Center"
                             VerticalOptions="Center" Margin="0,60,0,0" Spacing="8">
                    <Label Text="♡" FontSize="56"
                           HorizontalOptions="Center" TextColor="#BCBCC8"/>
                    <Label Text="No favourites yet"
                           TextColor="#BCBCC8" FontSize="17"
                           HorizontalOptions="Center" FontAttributes="Bold"/>
                    <Label Text="Tap ♡ on any project to add it here"
                           TextColor="#BCBCC8" FontSize="13"
                           HorizontalOptions="Center"/>
                </StackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>
</ContentPage>
