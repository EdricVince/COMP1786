<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectExpenseTracker.Views.ProjectDetailView"
             BackgroundColor="#F0F0FA"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Custom nav bar -->
        <Frame Grid.Row="0" BackgroundColor="#1E1E2D"
               CornerRadius="0" HasShadow="False" Padding="8,12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Text="← Back"
                        TextColor="White" BackgroundColor="Transparent"
                        FontSize="14" Clicked="OnBackTapped" Padding="4,0"/>
                <Label Grid.Column="1" x:Name="lblTitle"
                       Text="Project Detail" TextColor="White"
                       FontSize="17" FontAttributes="Bold"
                       VerticalOptions="Center" HorizontalOptions="Center"/>
                <Button Grid.Column="2" x:Name="btnFavShell"
                        Text="♡" TextColor="White"
                        BackgroundColor="Transparent"
                        FontSize="22" Clicked="OnFavouriteTapped" Padding="4,0"/>
            </Grid>
        </Frame>

        <ScrollView Grid.Row="1">
        <StackLayout Padding="16" Spacing="12">

            <!-- Budget card -->
            <Frame BackgroundColor="#1E1E2D" CornerRadius="20"
                   HasShadow="True" Padding="20,18">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                    <Label Grid.Row="0" x:Name="lblProjectName"
                           Text="" TextColor="White"
                           FontSize="20" FontAttributes="Bold"/>
                    <Label Grid.Row="1" x:Name="lblBudgetAmount"
                           Text="" TextColor="#AAAACC" FontSize="13" Margin="0,4,0,0"/>

                    <!-- Progress bar -->
                    <Frame Grid.Row="2" HeightRequest="8"
                           BackgroundColor="#3D3D5C" CornerRadius="4"
                           HasShadow="False" Padding="0"
                           Margin="0,12,0,12">
                        <BoxView x:Name="progressBar"
                                 BackgroundColor="#7B61FF"
                                 CornerRadius="4"
                                 HorizontalOptions="Start"
                                 WidthRequest="0" HeightRequest="8"/>
                    </Frame>

                    <Grid Grid.Row="3" ColumnDefinitions="*,*,*">
                        <StackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Spent" TextColor="#AAAACC" FontSize="11"/>
                            <Label x:Name="lblSpent" Text="$0"
                                   TextColor="#FF7043" FontSize="16" FontAttributes="Bold"/>
                        </StackLayout>
                        <StackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Remaining" TextColor="#AAAACC" FontSize="11"/>
                            <Label x:Name="lblRemaining" Text="$0"
                                   TextColor="#5EF5A0" FontSize="16" FontAttributes="Bold"/>
                        </StackLayout>
                        <StackLayout Grid.Column="2" Spacing="2">
                            <Label Text="Usage" TextColor="#AAAACC" FontSize="11"/>
                            <Label x:Name="lblUsage" Text="0%"
                                   TextColor="#7B61FF" FontSize="16" FontAttributes="Bold"/>
                        </StackLayout>
                    </Grid>
                </Grid>
            </Frame>

            <!-- Info card -->
            <Frame BackgroundColor="White" CornerRadius="16"
                   HasShadow="False" Padding="16">
                <StackLayout Spacing="10">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="Code" TextColor="#BCBCC8"
                               FontSize="12" WidthRequest="90"/>
                        <Label Grid.Column="1" x:Name="lblCode"
                               TextColor="#1E1E2D" FontSize="14" FontAttributes="Bold"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#EFEFEF"/>
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="Manager" TextColor="#BCBCC8"
                               FontSize="12" WidthRequest="90"/>
                        <Label Grid.Column="1" x:Name="lblManager"
                               TextColor="#1E1E2D" FontSize="14"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#EFEFEF"/>
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="Dates" TextColor="#BCBCC8"
                               FontSize="12" WidthRequest="90"/>
                        <Label Grid.Column="1" x:Name="lblDates"
                               TextColor="#1E1E2D" FontSize="13"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#EFEFEF"/>
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="Status" TextColor="#BCBCC8"
                               FontSize="12" WidthRequest="90"/>
                        <Frame x:Name="frmStatus" Padding="10,4" CornerRadius="8"
                               HasShadow="False" HorizontalOptions="Start">
                            <Label x:Name="lblStatus" FontSize="12" FontAttributes="Bold"/>
                        </Frame>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#EFEFEF"/>
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="Description" TextColor="#BCBCC8"
                               FontSize="12" WidthRequest="90"/>
                        <Label Grid.Column="1" x:Name="lblDescription"
                               TextColor="#7C7C8A" FontSize="13"/>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- Expenses header -->
            <Grid ColumnDefinitions="*,Auto" Margin="4,4,4,0">
                <Label Grid.Column="0" Text="Expenses"
                       TextColor="#1E1E2D" FontSize="18" FontAttributes="Bold"/>
                <Label Grid.Column="1" x:Name="lblExpenseCount"
                       TextColor="#7C7C8A" FontSize="13" VerticalOptions="Center"/>
            </Grid>

            <!-- Expense list -->
            <CollectionView x:Name="cvExpenses">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,0,0,8" BackgroundColor="White"
                               CornerRadius="14" HasShadow="False" Padding="14">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Label Grid.Column="0" Text="{Binding TypeEmoji}"
                                       FontSize="26" Margin="0,0,12,0"
                                       VerticalOptions="Center"/>
                                <StackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="{Binding Type}" TextColor="#1E1E2D"
                                           FontSize="14" FontAttributes="Bold"/>
                                    <Label Text="{Binding Claimant}"
                                           TextColor="#7C7C8A" FontSize="12"/>
                                    <Label Text="{Binding Date}"
                                           TextColor="#BCBCC8" FontSize="11"/>
                                    <Label Text="{Binding PaymentMethod}"
                                           TextColor="#BCBCC8" FontSize="11"/>
                                </StackLayout>
                                <StackLayout Grid.Column="2" Spacing="4">
                                    <Label Text="{Binding FormattedAmount}"
                                           TextColor="#1E1E2D" FontAttributes="Bold"
                                           FontSize="14" HorizontalOptions="End"/>
                                    <Frame Padding="8,3" CornerRadius="6"
                                           HasShadow="False"
                                           BackgroundColor="{Binding StatusBg}"
                                           HorizontalOptions="End">
                                        <Label Text="{Binding Status}"
                                               TextColor="{Binding StatusColor}"
                                               FontSize="10" FontAttributes="Bold"/>
                                    </Frame>
                                </StackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="No expenses recorded"
                           TextColor="#BCBCC8" FontSize="14"
                           HorizontalOptions="Center" Margin="0,20,0,0"/>
                </CollectionView.EmptyView>
            </CollectionView>

        </StackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
